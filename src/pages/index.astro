---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero';
import About from '../components/About.astro';
import Services from '../components/Services';
import Portfolio from '../components/Portfolio.astro';
import Pricing from '../components/Pricing.astro';
import Methodology from '../components/Methodology.astro';
import Ads from '../components/Ads.astro';
import Brands from '../components/Brands.astro';
import Contact from '../components/Contact';
import Footer from '../components/Footer.astro';
import MobileAppUI from '../components/MobileAppUI';

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout title="GLE Marketing - Agencia Digital Exponencial" description="Crecemos tu marca online. Diseño web, branding, gestión de redes y ads.">
	
	<!-- Top Navbar is hidden on mobile because we use the Bottom Nav in MobileAppUI -->
	<div class="hidden md:block">
		<Navbar />
	</div>

	<main class="pb-24 md:pb-0">
		<!-- CLASSIC HERO (DESKTOP) -->
		<div class="hidden md:block">
			<Hero client:load />
		</div>

		<!-- MOBILE APP HERO & DASHBOARD (MOBILE ONLY) -->
		<div class="block md:hidden">
			<MobileAppUI client:load />
		</div>

		<!-- CONTENT SECTIONS (VISIBLE ON BOTH) -->
		<div id="servicios"></div>
		<About />
		<Services client:load />
		<div id="portafolio"></div>
		<Portfolio />
		<Brands />
		<div id="precios"></div>
		<Pricing />
		<Methodology />
		<Ads />
		<div id="contacto"></div>
		<Contact client:load />
	</main>

	<!-- Footer hidden on mobile to avoid clashing with bottom nav, or we can leave it. Let's leave it but with padding bottom. -->
	<div class="hidden md:block">
		<Footer />
	</div>

</Layout>
