---
const getLink = (path: string) => {
  const base = import.meta.env.BASE_URL;
  const cleanBase = !base || base === '' ? '/' : (base.endsWith('/') ? base : base + '/');
  return cleanBase + path;
};

const navLinks = [
  { text: 'Inicio', href: getLink('#inicio') },
  { text: 'Servicios', href: getLink('#servicios') },
  { text: 'Portafolio', href: getLink('#portafolio') },
  { text: 'Precios', href: getLink('#precios') },
  { text: 'Contacto', href: getLink('#contacto') },
];
---


<header class="fixed w-full top-0 z-50 bg-[#030712]/60 backdrop-blur-2xl border-b border-white/10 shadow-[0_10px_40px_rgba(0,0,0,0.5)] transition-all duration-300">
  
  <!-- Textura fina y elegante (Fine Texture) -->
  <div class="absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:16px_16px] pointer-events-none select-none opacity-50 mix-blend-screen"></div>
  <div class="absolute bottom-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex justify-between items-center h-20">
      
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href={getLink('#inicio')} class="flex gap-2 items-center group">
          <img 
            src={getLink('logo-gle-light-trans.webp')} 
            alt="GLE Marketing" 
            class="h-12 w-auto object-contain transition-all duration-500 group-hover:scale-105 group-hover:drop-shadow-[0_0_15px_rgba(34,197,94,0.6)]" 
          />
        </a>
      </div>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex space-x-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-sm font-bold text-gray-300 hover:text-brand-green hover:drop-shadow-[0_0_10px_rgba(34,197,94,0.8)] transition-all duration-300 hover:-translate-y-1 relative group-hover:text-white"
          >
            {link.text}
          </a>
        ))}
      </nav>

      <!-- CTA Button -->
      <div class="hidden md:flex items-center gap-4">
        <a 
          href={getLink('cotizador')} 
          class="text-gray-300 hover:text-brand-green transition-transform duration-300 hover:-translate-y-1 hover:scale-110 relative"
          aria-label="Arma tu Plan"
          title="Arma tu Plan"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="8" cy="21" r="1"/>
            <circle cx="19" cy="21" r="1"/>
            <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
          </svg>
        </a>
        <a
          href={getLink('#contacto')}
          class="bg-brand-green text-brand-bg hover:bg-brand-green-hover px-6 py-2.5 rounded-lg font-bold text-sm transition-all duration-300 hover:shadow-[0_0_20px_rgba(34,197,94,0.4)] hover:scale-105"
        >
          Empezar
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center md:hidden z-50">
        <button id="mobile-menu-btn" type="button" class="text-gray-300 hover:text-white focus:outline-none transition-transform duration-300" aria-label="Toggle menu">
          <!-- Hamburger Icon (Default) -->
          <svg id="icon-menu" class="h-8 w-8 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <!-- Close Icon (Hidden by default) -->
          <svg id="icon-close" class="h-8 w-8 hidden transition-all duration-300 rotate-90 opacity-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed inset-0 top-20 bg-[#030712]/95 backdrop-blur-3xl z-40 hidden flex-col border-t border-white/10 transition-all duration-500 opacity-0 translate-y-[-10px] h-[calc(100vh-5rem)]">
    <nav class="flex flex-col px-6 py-8 space-y-2 overflow-y-auto w-full h-full pb-20">
      {navLinks.map((link, index) => (
        <a
          href={link.href}
          class="mobile-link text-2xl font-bold text-gray-300 hover:text-brand-green transition-all duration-300 border-b border-white/5 py-4 w-full flex items-center justify-between group"
        >
          {link.text}
          <svg class="w-6 h-6 opacity-50 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ))}
      
      <div class="pt-8 flex flex-col gap-4">
        <a 
          href={getLink('cotizador')} 
          class="mobile-link flex items-center justify-center gap-3 border-2 border-brand-green/30 text-brand-green hover:bg-brand-green/10 px-6 py-4 rounded-xl font-bold text-lg transition-all duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="8" cy="21" r="1"/>
            <circle cx="19" cy="21" r="1"/>
            <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
          </svg>
          Arma tu Plan
        </a>
        <a
          href={getLink('#contacto')}
          class="mobile-link bg-brand-green text-brand-bg hover:bg-brand-green-hover px-6 py-4 rounded-xl font-bold text-lg text-center transition-all duration-300 shadow-[0_0_20px_rgba(34,197,94,0.3)]"
        >
          Empezar Ahora
        </a>
      </div>
      
      <div class="mt-auto pt-10 flex justify-center">
         <p class="text-xs text-brand-green/40 font-semibold tracking-widest uppercase">GLE Marketing</p>
      </div>
    </nav>
  </div>
</header>

<script>
  function setupMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconMenu = document.getElementById('icon-menu');
    const iconClose = document.getElementById('icon-close');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    
    if (!btn || !menu) return;

    let isMenuOpen = false;

    const toggleMenu = () => {
      isMenuOpen = !isMenuOpen;
      
      if (isMenuOpen) {
        // Open Mobile Menu
        menu.classList.remove('hidden');
        // Delay to allow CSS transition to trigger after removing 'hidden'
        setTimeout(() => {
          menu.classList.remove('opacity-0', 'translate-y-[-10px]');
          menu.classList.add('opacity-100', 'translate-y-0');
        }, 10);
        
        // Toggle Icons
        iconMenu.classList.add('hidden', 'opacity-0', '-rotate-90');
        iconClose.classList.remove('hidden');
        setTimeout(() => {
          iconClose.classList.remove('opacity-0', 'rotate-90');
          iconClose.classList.add('opacity-100', 'rotate-0');
        }, 10);
        
        // Prevent body scrolling
        document.body.style.overflow = 'hidden';
      } else {
        // Close Mobile Menu
        menu.classList.remove('opacity-100', 'translate-y-0');
        menu.classList.add('opacity-0', 'translate-y-[-10px]');
        
        // Toggle Icons
        iconClose.classList.remove('opacity-100', 'rotate-0');
        iconClose.classList.add('opacity-0', 'rotate-90');
        
        setTimeout(() => {
          menu.classList.add('hidden');
          iconClose.classList.add('hidden');
          iconMenu.classList.remove('hidden');
          setTimeout(() => {
             iconMenu.classList.remove('opacity-0', '-rotate-90');
          }, 10);
        }, 300); // 300ms matches Tailwind duration-300
        
        // Restore body scrolling
        document.body.style.overflow = '';
      }
    };

    // Remove old listeners to prevent duplicates if Astro page changes
    const newBtn = btn.cloneNode(true);
    btn.parentNode?.replaceChild(newBtn, btn);
    newBtn.addEventListener('click', toggleMenu);

    mobileLinks.forEach(link => {
      const newLink = link.cloneNode(true);
      link.parentNode?.replaceChild(newLink, link);
      newLink.addEventListener('click', () => {
        if (isMenuOpen) toggleMenu();
      });
    });
  }

  // Run on first load
  setupMobileMenu();
  // Run on subsequent navigations if using Astro ViewTransitions
  document.addEventListener('astro:page-load', setupMobileMenu);
</script>




