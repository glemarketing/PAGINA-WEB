---
const plans = [
  {
    name: 'Plan 1 Mensual',
    subtitle: 'L. 4,000',
    priceDesc: '/mes (No incluye inversión Ads)',
    image: `${import.meta.env.BASE_URL}pricing_app_1.webp`,
    features: [
      '2 posts por semana (8 al mes)',
      '3 historias por semana',
      'Redacción de textos (copywriting)',
      'Manejo y programación',
      'Botones de contacto directo',
      'Planificación mensual de contenido',
      'Estrategia básica de publicaciones',
      'Reporte mensual de resultados'
    ],
    highlighted: false,
    btnText: 'Comprar Plan'
  },
  {
    name: 'Plan 2 Mensual',
    subtitle: 'L. 7,000',
    priceDesc: '/mes',
    image: `${import.meta.env.BASE_URL}pricing_app_2.webp`,
    features: [
      '3 posts por semana (12 al mes)',
      'Historias de lunes a viernes',
      '2 reels mensuales dinámicos',
      'Diseño y edición profesional',
      'Redacción orientada a ventas (copy)',
      'Planificación estratégica básica',
      'CTA con enlace directo a WhatsApp',
      'Segmentación publicitaria básica'
    ],
    highlighted: true,
    badge: 'RECOMENDADO',
    btnText: 'Elegir Plan'
  },
  {
    name: 'Plan 3 Mensual',
    subtitle: 'L. 12,000',
    priceDesc: '/mes',
    image: `${import.meta.env.BASE_URL}pricing_app_3.webp`,
    features: [
      '5 posts por semana (20 al mes)',
      'Historias diarias estratégicas',
      '8 reels mensuales de alto impacto',
      'Diseño, Sesión de foto y video',
      'Estrategia mensual personalizada',
      'Segmentación publicitaria optimizada',
      'CTA con enlace al WhatsApp',
      'Optimización profesional de perfil'
    ],
    highlighted: false,
    btnText: 'Consultar Plan'
  }
];
---
<style>
  /* Ocultar barra de scroll para carrusel horizontal */
  .no-scrollbar::-webkit-scrollbar {
      display: none;
  }
  .no-scrollbar {
      -ms-overflow-style: none; 
      scrollbar-width: none; 
  }
</style>

<section id="precios" class="py-24 bg-brand-bg relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight mb-4">Planes de Inversión</h2>
      <p class="text-gray-400">Modelos de crecimiento adaptados a la etapa de tu empresa</p>
    </div>

    <div class="flex overflow-x-auto snap-x snap-mandatory md:grid md:grid-cols-3 gap-5 md:gap-8 pb-8 md:pb-0 -mx-4 px-4 md:mx-auto md:px-0 items-stretch max-w-5xl no-scrollbar">
      {plans.map(plan => (
        <div class={`w-[85vw] sm:w-[340px] md:w-auto flex-shrink-0 snap-center group rounded-2xl p-6 md:p-8 border hover:scale-105 transition-all duration-500 flex flex-col ${plan.highlighted ? 'bg-white text-[#030712] border-white md:scale-105 z-10 shadow-[0_0_50px_rgba(255,255,255,0.1)] relative md:hover:scale-[1.08]' : 'bg-brand-card border-white/10 text-white hover:border-brand-green/50'}`}>
          
          <!-- Image with Hover Blur Effect -->
          <div class="h-32 md:h-48 w-full mb-5 md:mb-6 overflow-hidden rounded-xl relative -mt-2">
            <img 
              src={plan.image} 
              alt={plan.subtitle} 
              class="w-full h-full object-cover transition-all duration-500 group-hover:blur-sm group-hover:scale-110 group-hover:opacity-80" 
            />
            <div class="absolute inset-0 mix-blend-multiply opacity-50 bg-black"></div>
          </div>

          {plan.badge && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-brand-green text-[#030712] border border-brand-green text-xs font-black px-4 py-1 rounded-full uppercase tracking-wider shadow-lg">
              {plan.badge}
            </div>
          )}

          <h3 class={`text-sm tracking-wider font-bold mb-2 uppercase ${plan.highlighted ? 'text-gray-500' : 'text-brand-green'}`}>{plan.name}</h3>
          <div class="flex flex-col mb-6 md:mb-8 border-b pb-5 md:pb-6 border-white/10">
            <div class="flex items-end gap-1">
              <span class={`text-3xl md:text-4xl font-black tracking-tight ${plan.highlighted ? 'text-black' : 'text-white'}`}>{plan.subtitle}</span>
            </div>
            {plan.priceDesc && <span class={`text-[11px] md:text-xs mt-1 font-medium ${plan.highlighted ? 'text-gray-500' : 'text-gray-400'}`}>{plan.priceDesc}</span>}
          </div>

          <ul class="space-y-4 mb-8">
            {plan.features.map(feature => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-brand-green" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                <span class={`text-[13px] md:text-sm ${plan.highlighted ? 'text-gray-800 font-semibold' : 'text-gray-300'}`}>{feature}</span>
              </li>
            ))}
          </ul>

          <a href="#contacto" onclick={`window.dispatchEvent(new CustomEvent('plan-selected', { detail: { plan: '${plan.name}' } }))`} class={`block w-full text-center py-4 px-6 rounded-xl font-bold text-sm tracking-wide transition-all duration-300 transform ${plan.highlighted ? 'bg-[#030712] text-white hover:bg-brand-green hover:text-black shadow-xl hover:shadow-2xl hover:-translate-y-1' : 'border-2 border-white/20 hover:border-brand-green hover:bg-brand-green/10 hover:text-brand-green text-white hover:-translate-y-1'}`}>
            {plan.btnText}
          </a>
        </div>
      ))}
    </div>

    <!-- Botón hacia el Cotizador Personalizado -->
    <div class="mt-16 flex justify-center pb-8 md:pb-0">
      <a href={import.meta.env.BASE_URL + 'cotizador'} class="inline-flex overflow-hidden relative items-center gap-3 bg-[#030712] border border-white/10 rounded-2xl px-8 py-4 font-black shadow-[0_10px_30px_rgba(0,0,0,0.5)] hover:scale-105 hover:border-brand-green/50 hover:shadow-[0_0_40px_rgba(34,197,94,0.15)] transition-all duration-300 group">
        <div class="absolute inset-0 bg-gradient-to-r from-brand-green to-teal-400 opacity-0 group-hover:opacity-10 transition-opacity"></div>
        <div class="w-10 h-10 rounded-full bg-brand-green/20 flex items-center justify-center border border-brand-green/30 group-hover:bg-brand-green group-hover:text-[#030712] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-green group-hover:text-[#030712]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
        </div>
        <div class="flex flex-col text-left">
          <span class="text-white text-base tracking-tight leading-none mb-1">Arma tu propio paquete</span>
          <span class="text-gray-400 text-[11px] uppercase tracking-wider font-bold group-hover:text-brand-green/80 transition-colors">Ir al Catálogo Interactivo</span>
        </div>
      </a>
    </div>

  </div>
</section>





