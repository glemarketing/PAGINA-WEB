---
import PortfolioSlider from './PortfolioSlider';
---

<section id="portafolio" class="py-24 bg-brand-bg relative focus:outline-none outline-none">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-12">
      <div>
        <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight">Proyectos Premium</h2>
      </div>
      <a href="#" class="text-brand-green hover:text-brand-green-hover font-medium flex items-center gap-2 mt-4 md:mt-0 transition-colors">
        Explorar todo
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>

    <div class="mt-8">
      <PortfolioSlider client:visible />
    </div>

  </div>
</section>
