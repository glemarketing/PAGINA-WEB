---
// Ads.astro
---

<section id="ads" class="py-24 bg-brand-bg relative overflow-hidden">
  <!-- Dynamic Background Effects -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 -left-1/4 w-1/2 h-1/2 bg-blue-600/20 blur-[120px] rounded-full mix-blend-screen opacity-50 animate-pulse"></div>
    <div class="absolute bottom-1/4 -right-1/4 w-1/2 h-1/2 bg-purple-600/20 blur-[120px] rounded-full mix-blend-screen opacity-50 animate-pulse" style="animation-delay: 2s;"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- 1. INTRO (SHORT + POWERFUL) -->
    <div class="text-center max-w-4xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-green/10 border border-brand-green/30 text-brand-green text-sm font-bold tracking-widest uppercase mb-6 shadow-[0_0_15px_rgba(34,197,94,0.3)]">
        <span class="w-2 h-2 rounded-full bg-brand-green animate-ping"></span>
        Targeting de Precisión
      </div>
      <h2 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight mb-6 leading-tight">
        Precisión Absoluta. <br/> <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-400 via-purple-500 to-brand-green">Resultados Reales.</span>
      </h2>
      <p class="text-xl text-gray-300 md:text-2xl font-light mb-8">
        No solo lanzamos anuncios — posicionamos tu marca frente a las personas correctas, en el momento exacto.
      </p>
      <p class="text-gray-400 max-w-3xl mx-auto">
        Utilizamos estrategias avanzadas de segmentación de audiencias basadas en <strong class="text-white">Intereses, Comportamientos, Demografía, Ubicación y Actividad Online</strong>. Nuestro objetivo primordial: maximizar la conversión real, no solo el alcance vacío.
      </p>
    </div>

    <!-- 5. VISUAL ELEMENT (Targeting Visualization) -->
    <div class="mb-24 relative w-full max-w-5xl mx-auto hidden md:block">
      <div class="h-[450px] rounded-2xl border border-white/10 bg-black/50 backdrop-blur-xl p-8 overflow-hidden relative shadow-2xl">
        
        <!-- Animated Background Grid -->
        <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,#000_10%,transparent_100%)] opacity-30"></div>
        
        <!-- Connection Lines (SVG) -->
        <svg class="absolute inset-0 w-full h-full pointer-events-none opacity-60 z-0" style="filter: drop-shadow(0 0 5px rgba(34,197,94,0.5))">
          <!-- Flow Line 1 -->
          <path d="M 150 150 C 300 200, 400 100, 500 200" fill="none" stroke="#22c55e" stroke-width="2" stroke-dasharray="6 6" class="animate-dash">
          </path>
          <!-- Flow Line 2 -->
          <path d="M 800 300 C 600 300, 600 200, 500 200" fill="none" stroke="#22c55e" stroke-width="2" stroke-dasharray="6 6" class="animate-dash" style="animation-direction: reverse;">
          </path>
        </svg>

        <!-- Center Hub -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 rounded-full border border-brand-green/20 bg-brand-green/5 flex items-center justify-center animate-[spin_15s_linear_infinite] z-0">
          <div class="w-32 h-32 rounded-full border border-purple-500/20 bg-purple-500/5 animate-[spin_10s_linear_infinite_reverse]"></div>
        </div>

        <!-- Dynamic Data Overlay (Center) -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center z-20 bg-[#030712]/80 px-6 py-4 rounded-xl border border-white/10 backdrop-blur-md shadow-[0_0_30px_rgba(34,197,94,0.15)]">
          <div class="text-[10px] text-gray-400 tracking-widest uppercase mb-1">Machine Learning</div>
          <div class="text-3xl font-black text-white font-mono flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-brand-green animate-ping shadow-[0_0_10px_rgba(34,197,94,1)]"></span>
            Optimizando...
          </div>
          <div class="text-xs text-brand-green mt-2 font-mono" id="live-bid">Puja Actual: $0.45</div>
        </div>

        <!-- Floating Ad Card 1 (Meta/Facebook style) -->
        <div class="absolute top-10 left-[10%] w-72 bg-white/5 border border-white/10 rounded-xl p-4 backdrop-blur-md shadow-2xl animate-float z-10">
          <!-- Header -->
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-brand-green to-blue-600 flex items-center justify-center">
              <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </div>
            <div>
              <div class="h-2 w-20 bg-gray-400 rounded-sm mb-1.5 opacity-80"></div>
              <div class="h-1.5 w-12 bg-gray-500 rounded-sm opacity-60"></div>
            </div>
            <div class="ml-auto flex items-center gap-1 text-[9px] text-gray-400 bg-black/40 px-2 py-0.5 rounded">
              Publicidad
            </div>
          </div>
          <!-- Creative -->
          <div class="w-full h-32 bg-gray-900 rounded-lg mb-3 relative overflow-hidden group">
            <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=600&auto=format&fit=crop')] bg-cover bg-center opacity-60 group-hover:scale-105 transition-transform duration-[2s]"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
            <div class="absolute bottom-2 left-2 right-2 flex justify-between items-end">
              <div>
                <div class="text-[10px] text-white font-bold">Oferta Limitada</div>
                <div class="text-[9px] text-gray-300">Descubre cómo escalar</div>
              </div>
              <div class="bg-brand-green text-[#030712] text-[9px] font-bold px-2 py-1 rounded">Ver Más</div>
            </div>
          </div>
          <!-- Live Metrics -->
          <div class="flex justify-between items-center border-t border-white/5 pt-2">
            <div class="flex gap-2 items-center">
              <div class="flex -space-x-2">
                <div class="w-5 h-5 rounded-full bg-blue-500 border border-[#030712] flex items-center justify-center text-[10px]">👍</div>
                <div class="w-5 h-5 rounded-full bg-red-500 border border-[#030712] flex items-center justify-center text-[10px]">❤️</div>
              </div>
              <span class="text-[11px] text-gray-300 font-mono" id="live-likes">2,408</span>
            </div>
            <div class="bg-brand-green/20 text-brand-green text-[10px] px-2 py-1 rounded font-mono border border-brand-green/30">
              CTR: <span class="font-bold">5.2%</span>
            </div>
          </div>
        </div>

        <!-- Floating Analytics Card 2 -->
        <div class="absolute bottom-6 right-[10%] w-64 bg-white/5 border border-white/10 rounded-xl p-5 backdrop-blur-md shadow-2xl animate-float-delayed z-10">
          <div class="flex items-center gap-3 mb-4 border-b border-white/10 pb-3">
            <div class="w-8 h-8 rounded-md bg-gradient-to-tr from-purple-600 to-blue-500 flex items-center justify-center">
              <svg class="w-4 h-4 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
            </div>
            <div>
              <div class="text-[10px] text-gray-400 font-medium tracking-wide uppercase">Campaña de Conversión</div>
              <div class="text-[13px] text-white font-bold tracking-tight">Retargeting Caliente</div>
            </div>
          </div>
          
          <div class="grid grid-cols-2 gap-4">
            <div>
                <div class="text-[10px] text-gray-400 mb-1 leading-none">ROAS</div>
                <div class="text-xl font-black text-brand-green font-mono tracking-tighter" id="live-roas">4.8x</div>
                <div class="text-[10px] text-brand-green flex items-center gap-0.5 mt-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
                  12.5%
                </div>
            </div>
            <div>
                <div class="text-[10px] text-gray-400 mb-1 leading-none">Costo x Lead</div>
                <div class="text-xl font-black text-white font-mono tracking-tighter">-$2.10</div>
                <div class="h-1 w-full bg-white/10 rounded-full mt-2 overflow-hidden relative">
                  <div class="absolute top-0 left-0 h-full bg-brand-green w-[85%] rounded-full shadow-[0_0_10px_rgba(34,197,94,0.8)]"></div>
                </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- 2. WHAT WE DO (SEGMENTATION EXPLAINED SIMPLY) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-24">
      {
        [
          { title: 'Audience Research', desc: 'Analizamos a tu cliente ideal y el comportamiento del mercado con máxima profundidad.', color: 'text-blue-400', border: 'hover:border-blue-500/50', shadow: 'hover:shadow-[0_0_30px_rgba(59,130,246,0.15)]' },
          { title: 'Smart Targeting', desc: 'Segmentamos audiencias utilizando datos reales (intereses, comportamientos, ubicación).', color: 'text-purple-400', border: 'hover:border-purple-500/50', shadow: 'hover:shadow-[0_0_30px_rgba(168,85,247,0.15)]' },
          { title: 'Ad Optimization', desc: 'Mejoramos constantemente las campañas basándonos en métricas de rendimiento en tiempo real.', color: 'text-brand-green', border: 'hover:border-brand-green/50', shadow: 'hover:shadow-[0_0_30px_rgba(34,197,94,0.15)]' },
          { title: 'Retargeting', desc: 'Re-enganchamos a los usuarios que ya mostraron interés real en tu marca para cerrar la venta.', color: 'text-white', border: 'hover:border-white/30', shadow: 'hover:shadow-[0_0_30px_rgba(255,255,255,0.1)]' },
        ].map((item, index) => (
          <div class={`bg-black/30 border border-white/5 p-8 rounded-2xl transition-all duration-500 hover:-translate-y-2 group relative overflow-hidden ${item.border} ${item.shadow}`}>
             <div class="absolute top-0 left-0 w-full h-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-gradient-to-r from-transparent via-current to-transparent"></div>
             <span class={`text-5xl font-black opacity-10 absolute -top-2 -right-2 ${item.color}`}>0{index + 1}</span>
             <h3 class={`text-xl font-bold mb-3 ${item.color}`}>{item.title}</h3>
             <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))
      }
    </div>

    <!-- 3 & 4. WHY IT MATTERS & SERVICES INCLUDED -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-32 items-center">
      <!-- Why it matters -->
      <div>
        <h3 class="text-3xl font-bold text-white mb-6">Por qué es Vital.</h3>
        <p class="text-gray-400 mb-6 text-lg">
          Sin la segmentación adecuada, los anuncios desperdician presupuesto y llegan a la audiencia equivocada. <strong class="text-white">Con nosotros es diferente.</strong>
        </p>
        <ul class="space-y-4">
          {['Tasas de conversión más altas', 'Mejor Retorno de Inversión (ROI)', 'Adquisición de clientes más calificados', 'Crecimiento de negocio acelerado'].map(benefit => (
            <li class="flex items-center gap-3">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-green/20 flex items-center justify-center border border-brand-green/50">
                <svg class="w-3 h-3 text-brand-green" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-white font-medium">{benefit}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services Included -->
      <div class="bg-gradient-to-br from-white/5 to-white/0 border border-white/10 rounded-3xl p-8 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-purple-500/10 blur-[50px] -z-10"></div>
        <h3 class="text-2xl font-bold text-white mb-6">Servicios Incluidos</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            'Facebook & Instagram Ads',
            'Estrategia de Segmentación',
            'Configuración & Gestión',
            'Optimización de Performance',
            'Campañas de Retargeting',
            'Contenido Creativo (Ads/Video)'
          ].map(service => (
            <div class="bg-black/40 border border-white/5 rounded-xl p-4 flex items-center gap-3 hover:border-brand-green/30 transition-colors">
              <div class="w-2 h-2 rounded-full bg-brand-green shadow-[0_0_5px_rgba(34,197,94,0.8)]"></div>
              <span class="text-sm text-gray-300">{service}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- 6 & 7. CTA & CONTACT MICRO-SECTION -->
    <div class="bg-brand-green border border-brand-green rounded-3xl overflow-hidden relative flex flex-col lg:flex-row shadow-[0_0_50px_rgba(34,197,94,0.15)]">
      
      <!-- CTA Copy with Pricing -->
      <div class="p-12 lg:p-16 lg:w-1/2 flex flex-col justify-center relative z-10">
        <div class="inline-block bg-[#030712]/10 border border-black/10 text-[#030712] px-3 py-1 rounded-sm text-sm font-bold w-fit mb-4">Meta Ads</div>
        <h2 class="text-4xl md:text-5xl font-black text-[#030712] tracking-tight mb-4 leading-tight">
          ¿Listo para Llegar a la Audiencia Correcta?
        </h2>
        <div class="mb-8 border-b border-[#030712]/10 pb-6">
          <p class="text-xl text-[#030712]/80 font-medium mb-2">
            Configuración de campañas <strong class="text-[#030712] font-black">desde L. 1,500</strong>
          </p>
          <p class="text-sm text-[#030712]/60 font-medium">
            *Precio varía según rango y duración de la campaña (No incluye inversión).
          </p>
        </div>
        <button class="bg-[#030712] text-brand-green font-bold px-8 py-4 rounded-xl hover:bg-black hover:scale-105 transition-all duration-300 w-fit flex items-center gap-3 group shadow-xl">
          Consultar por Campañas
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </div>

      <!-- Contact Form -->
      <div class="p-12 lg:p-16 lg:w-1/2 bg-brand-bg text-white relative">
        <!-- Connecting angle visual line between green section and dark section -->
        <div class="hidden lg:block absolute top-0 -left-6 w-12 h-full bg-brand-bg transform skew-x-[-12deg] z-0"></div>
        
        <div class="relative z-10 max-w-sm mx-auto lg:mx-0">
          <p class="text-gray-400 mb-6">Cuéntanos sobre tu negocio y te mostraremos cómo alcanzar a tus clientes ideales.</p>
          
          <form class="space-y-4">
            <div>
              <input type="text" placeholder="Tu Nombre o Empresa" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-brand-green focus:ring-1 focus:ring-brand-green transition-colors" />
            </div>
            <div>
              <input type="text" placeholder="¿Cuál es tu objetivo principal?" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-brand-green focus:ring-1 focus:ring-brand-green transition-colors" />
            </div>
            <button type="submit" class="w-full bg-brand-green/10 text-brand-green border border-brand-green/50 hover:bg-brand-green hover:text-brand-bg font-bold px-4 py-3 rounded-lg transition-colors">
              Enviar Solicitud
            </button>
          </form>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px) scale(1); }
    50% { transform: translateY(-15px) scale(1.02); }
  }
  @keyframes dash {
    to { stroke-dashoffset: -20; }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  .animate-float-delayed {
    animation: float 7s ease-in-out infinite reverse;
  }
  .animate-dash {
    animation: dash 1s linear infinite;
  }
</style>
