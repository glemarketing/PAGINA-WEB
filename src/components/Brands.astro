---
import BrandSlider from './BrandSlider';
---

<section id="marcas" class="py-24 bg-brand-bg relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-green/10 border border-brand-green/30 text-brand-green text-sm font-bold tracking-widest uppercase mb-6 shadow-[0_0_15px_rgba(34,197,94,0.3)]">
        <span class="w-2 h-2 rounded-full bg-brand-green animate-ping"></span>
        Confianza
      </div>
      <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight mb-4">Marcas que Confían en Nosotros</h2>
      <p class="text-gray-400 text-lg">Hemos impulsado la presencia digital y el diseño de múltiples empresas.</p>
    </div>

    <div class="mt-8">
      <BrandSlider client:visible />
    </div>

  </div>
</section>
