---
const steps = [
  {
    num: '01',
    title: 'Estrategia',
    desc: 'Evaluamos tu mercado y competencia elaborando una proyección de escalabilidad agresiva.'
  },
  {
    num: '02',
    title: 'Creación',
    desc: 'Producimos direccionamiento visual, contenido a nivel de diseño corporativo web impecable.'
  },
  {
    num: '03',
    title: 'Publicación',
    desc: 'Distribuimos los esfuerzos en canales para maximizar el alcance de visualizaciones.'
  },
  {
    num: '04',
    title: 'Optimización',
    desc: 'Revisión constante para el desarrollo, mejorando el retorno de inversión.'
  }
];
---

<section class="py-24 bg-brand-bg border-t border-b border-white/5 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-24">
      
      <div class="lg:col-span-1">
        <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight sticky top-32">
          Nuestra<br />Metodología
        </h2>
      </div>

      <div class="lg:col-span-2 relative">
        <div class="absolute left-[23px] top-4 bottom-4 w-px bg-white/10 hidden md:block"></div>
        <div class="space-y-16">
          {steps.map(step => (
            <div class="relative flex flex-col md:flex-row gap-6 md:gap-12 group">
              <div class="text-5xl md:text-6xl font-black text-brand-green/20 group-hover:text-brand-green transition-colors duration-500 font-mono tracking-tighter w-20 flex-shrink-0 bg-brand-bg relative z-10">
                {step.num}
              </div>
              <div class="flex-1 pt-2 md:pt-4">
                <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-brand-green transition-colors duration-300">{step.title}</h3>
                <p class="text-gray-400 leading-relaxed text-lg">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
